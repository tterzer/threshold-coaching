{
  "headers": [
    {
      "source": "/:path*.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/races", "destination": "/api/races" },
    { "source": "/api/athlete-profile", "destination": "/api/athlete-profile" },
    { "source": "/api/ai-conversations", "destination": "/api/ai-conversations" },
    { "source": "/api/nutrition-food-history", "destination": "/api/nutrition-food-history" },
    { "source": "/api/nutrition-food", "destination": "/api/nutrition-food" },
    { "source": "/api/nutrition-log", "destination": "/api/nutrition-log" },
    { "source": "/api/nutrition-weight", "destination": "/api/nutrition-weight" },
    { "source": "/api/nutrition-week", "destination": "/api/nutrition-week" },
    { "source": "/api/nutrition-profile", "destination": "/api/nutrition-profile" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
